{
  "name": "Automata Learning",
  "image": "automata_learning",
  "workspaceFolder": "/workdir",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workdir,type=bind,consistency=cached",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/bin/python",
        "python.terminal.activateEnvironment": false,
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter"
      ]
    }

  },
  "postCreateCommand": "apt-get install -y git && python --version && which ltlsynt && which syfco",
  "remoteUser": "root",
  "mounts": [
    "source=${localWorkspaceFolder}/src/data/Kuhn_Poker,target=/workdir/Kuhn_Poker,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind,consistency=cached,readonly",
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,consistency=cached,readonly"
  ]
}