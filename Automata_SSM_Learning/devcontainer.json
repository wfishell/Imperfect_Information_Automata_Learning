{
  "name": "Automata Learning",
  "image": "automata_learning",
  "workspaceFolder": "/workdir",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/bin/python",
        "python.terminal.activateEnvironment": false,
        "editor.formatOnSave": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter"
      ]
    }
    
  },
  "postCreateCommand": "python --version && which ltlsynt && which syfco",
  "remoteUser": "root",
  "mounts": [
  "source=${localWorkspaceFolder}/Kuhn_Poker,target=/workdir/Kuhn_Poker,type=bind,consistency=cached"
]
}